class Solution {
    public int missingNumber(int[] nums) {
        int n = nums.length;
        int actualSum = 0;
        for(int i = 0; i < nums.length; i++)
        {
            actualSum += nums[i];
        }
        int total = n;
        int expSum = total * (total + 1)/2;
        int missNum = expSum - actualSum;

        return missNum; 
    }
}